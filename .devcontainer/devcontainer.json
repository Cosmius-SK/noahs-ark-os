{
    "name": "Noah's Ark OS",
    "image": "mcr.microsoft.com/devcontainers/python:3.12",
    "postCreateCommand": "pip install google-genai ipywidgets jupyter nbformat openpyxl python-docx && jupyter nbextension enable --py widgetsnbextension",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-toolsai.jupyter",
                "ms-toolsai.jupyter-renderers"
            ],
            "settings": {
                "python.defaultInterpreterPath": "/usr/local/bin/python",
                "jupyter.notebookFileRoot": "${workspaceFolder}"
            }
        }
    },
    "forwardPorts": [8888],
    "remoteEnv": {
        "GEMINI_API_KEY": "${localEnv:GEMINI_API_KEY}"
    }
}
